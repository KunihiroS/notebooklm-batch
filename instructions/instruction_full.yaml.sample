# NotebookLM batch instruction sample
# Full sample covering all supported content types and option fields.
# Save as .yaml/.yml under instructions/ and pass it to run_batch.py.

settings:
  language: en
  notify:
    github_issue: 1
    # github_repo: "your-account/notebooklm-batch"

tasks:
  - source: "https://www.youtube.com/watch?v=dQw4w9WgXcQ"
    title: "AI News Weekly"
    contents:
      - type: podcast
        prompt: "Create an engaging podcast covering the overall picture in the first half and diving into individual topics in the second half."
        options:
          format: deep-dive
          length: long
        # format: deep-dive | brief | critique | debate
        # length: short | default | long

      - type: image
        prompt: "Create an infographic that captures the key points of the video at a glance. Highlight 3 main topics visually with concise captions."
        options:
          orientation: landscape
          detail: detailed
        # orientation: landscape | portrait | square
        # detail: concise | standard | detailed

      - type: slide
        prompt: "Organize the key points and insights into a slide deck suitable for internal sharing."
        options:
          format: presenter
          length: default
        # format: detailed | presenter
        # length: default | short

      - type: video
        prompt: "Structure the content as an explainer video for beginners, adding brief clarifications for technical terms."
        options:
          format: explainer
          style: whiteboard
        # format: explainer | brief
        # style: auto-select | classic | whiteboard | kawaii | anime | watercolor | retro-print | heritage | paper-craft

      - type: report
        prompt: "Summarize the key points of the video as a briefing document."
        options:
          format: briefing-doc
        # format: briefing-doc | faq | study-guide | timeline | ...

      - type: quiz
        prompt: "Create a quiz to check understanding of the key concepts covered in the video."
        options:
          quantity: standard
          difficulty: medium
        # quantity: standard | more | fewer
        # difficulty: easy | medium | hard

      - type: flashcards
        prompt: "Turn the important terms and concepts from the video into flashcards."
        options:
          quantity: standard
          difficulty: medium

      - type: data-table
        prompt: "List the products, services, and figures mentioned in the video in a table."

  - source: "https://example.com/article"
    title: "Web Article Summary"
    contents:
      - type: report
        prompt: "Summarize the key points of the article."
        options:
          format: briefing-doc

      - type: podcast
        prompt: "Summarize briefly including a critical perspective."
        options:
          format: critique
          length: short
